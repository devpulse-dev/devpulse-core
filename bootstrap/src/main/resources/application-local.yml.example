# =============================================================================
# ШАБЛОН для локальной разработки.
#
# 1. Скопировать в `application-local.yml` (этот файл в .gitignore — никогда не коммитится):
#    cp bootstrap/src/main/resources/application-local.yml.example \
#       bootstrap/src/main/resources/application-local.yml
#
# 2. Подставить реальные значения ниже (токены, репозитории).
#
# 3. Запускать приложение с активным профилем `local`:
#    - IntelliJ Run Configuration → Active profiles: local
#    - Через CLI: SPRING_PROFILES_ACTIVE=local mvn -pl bootstrap spring-boot:run
#    - Через VM options: -Dspring.profiles.active=local
#
# Spring автоматически наложит этот файл поверх application.yml — приоритет
# у профиля local выше базового.
# =============================================================================

git:
  repositories:
    - https://scm.x5.ru/gkr/xrg-core.git
    - https://scm.x5.ru/gkr/xrg-markable.git
    # … добавить остальные
  token: PASTE_YOUR_GIT_TOKEN_HERE
  # cache-directory можно не указывать — берётся ${user.home}/Documents/git-cache/

kaiten:
  api:
    url: https://kaiten.x5.ru/api/latest
    web-base-url: https://kaiten.x5.ru
    token: PASTE_YOUR_KAITEN_TOKEN_HERE
    # Для машин без корпоративного X5 CA в JVM truststore.
    # См. README раздел «SSL: подключение к корпоративному Kaiten».
    insecure-ssl: true

gitlab:
  api:
    # base-url по умолчанию https://scm.x5.ru/api/v4 — можно не указывать.
    # token: можно не указывать — берётся git.token (тот же PAT с read_api).
    # projects: можно не указывать — деривятся из git.repositories выше.
    email-domain: x5.ru
    # scm.x5.ru за внутренним X5 CA — как и Kaiten.
    insecure-ssl: true

# === OAuth2-вход через GitLab (ADR-13) ===
# Раскомментируй и подставь реальные client-id/secret из OAuth-приложения GitLab
# (scm.x5.ru → Settings → Applications; Redirect URI:
# http://localhost:8080/login/oauth2/code/gitlab, scope: read_user). Этот блок
# переопределит дефолтные "default" из application.yml (которые нужны лишь чтобы
# не ронять старт в CI без env).
#spring:
#  security:
#    oauth2:
#      client:
#        registration:
#          gitlab:
#            client-id: PASTE_OAUTH_CLIENT_ID_HERE
#            client-secret: PASTE_OAUTH_CLIENT_SECRET_HERE
